# Backend Environment Template
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mentalhealth

# JWT
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRE=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Firebase Admin (optional for token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# CORS
CORS_ORIGIN=https://mentalhealthapp-ba7bb.web.app,http://localhost:5173,http://localhost:3000
SOCKET_IO_CORS_ORIGIN=https://mentalhealthapp-ba7bb.web.app,http://localhost:5173,http://localhost:3000
